# PostgreSQL Configuration (escolha uma opção)

# Opção 1: Connection string completa
DATABASE_URL=postgresql://user:password@host:5432/database

# Opção 2: Variáveis separadas
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=consultoria_campo

# Frontend
VITE_APP_NAME=Consultoria de Campo
