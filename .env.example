# .env.example
# Copie este arquivo para .env e preencha com suas chaves

# Supabase Configuration
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_sua_chave_aqui

# Service Role Key (para operações administrativas - contorna RLS)
# ⚠️ ATENÇÃO: Use apenas em desenvolvimento. Em produção, use backend com esta chave.
SUPABASE_SERVICE_ROLE_KEY=sbp_sua_chave_service_role_aqui

# Outras configurações
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sb_publishable_sua_chave_aqui
GITHUB_TOKEN=seu_github_token_aqui

